# Copy to `.env` and fill in. All vars use Nuxt's NUXT_ runtimeConfig convention.

# ── Public ─────────────────────────────────────────────────────────────
# Public base URL of the site (used for Stripe success/cancel URLs + OG images)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Stripe publishable key (safe to expose; currently only the secret key is used)
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── Stripe (server-only secrets) ───────────────────────────────────────
NUXT_STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen` (dev) or the Stripe dashboard webhook endpoint (prod).
# If unset, the webhook skips signature verification (DEV ONLY).
NUXT_STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Lulu Print API (server-only) ───────────────────────────────────────
# Leave MOCK=true (or credentials blank) to run fully mocked, no real orders.
NUXT_LULU_MOCK=true
NUXT_LULU_CLIENT_KEY=
NUXT_LULU_CLIENT_SECRET=
# Sandbox: https://api.sandbox.lulu.com   Production: https://api.lulu.com
NUXT_LULU_BASE_URL=https://api.sandbox.lulu.com
NUXT_LULU_CONTACT_EMAIL=orders@doreanpress.org

# ── Email (Resend) ─────────────────────────────────────────────────────
# If the key is blank, emails are logged to the console instead of sent.
NUXT_RESEND_API_KEY=
# Must be a verified Resend sender. "Name <addr>" form is fine.
NUXT_FROM_EMAIL=Dorean Press <hello@doreanpress.org>
# Optional: get a copy of every new pay-it-forward request.
NUXT_PRESS_EMAIL=
